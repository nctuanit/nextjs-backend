{
  "name": "next-js-backend",
  "version": "1.0.3",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./index.ts --outdir ./dist --target node && bun x tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "push": "./scripts/push.sh"
  },
  "description": "A high-performance NestJS-like backend library for Bun and Next.js Edge, powered by Elysia.",
  "author": "Tuan Nguyen",
  "license": "MIT",
  "keywords": [
    "elysia",
    "nestjs",
    "bun",
    "nextjs",
    "library",
    "edge",
    "decorators",
    "dependency-injection"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nctuanit/nextjs-backend.git"
  },
  "bugs": {
    "url": "https://github.com/nctuanit/nextjs-backend/issues"
  },
  "files": [
    "dist",
    "src",
    "index.ts",
    "globals.d.ts",
    "README.md"
  ],
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@sinclair/typebox": "^0.34.48",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "elysia": "^1.4.27",
    "elysia-helmet": "^3.0.0",
    "elysia-rate-limit": "^4.5.1",
    "jose": "^6.2.1",
    "reflect-metadata": "^0.2.2"
  }
}
